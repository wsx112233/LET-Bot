AI_API_KEY=replace-with-your-openai-compatible-api-key
AI_BASE_URL=https://api.siliconflow.cn/v1
AI_MODEL=Qwen/Qwen2.5-7B-Instruct
AI_MODEL_FALLBACKS=Qwen/Qwen3-8B
AI_TIMEOUT=45
AI_MAX_RETRIES=0
AI_CONTENT_LIMIT=8000
SCAN_INTERVAL_MIN=90
SCAN_INTERVAL_MAX=180
BLOCKED_SLEEP_SECONDS=1800

TG_BOT_TOKEN=replace-with-your-telegram-bot-token
TG_CHAT_ID=replace-with-your-channel-or-chat-id
TG_PARSE_MODE=MarkdownV2
TG_DISABLE_WEB_PREVIEW=true

TZ=UTC
ADMIN_HOST=127.0.0.1
ADMIN_PORT=2918
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
